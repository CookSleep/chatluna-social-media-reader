{
    "name": "koishi-plugin-chatluna-social-media-reader",
    "description": "为 ChatLuna 提供哔哩哔哩与小红书社交媒体读取工具",
    "version": "0.1.2",
    "homepage": "https://github.com/CookSleep/chatluna-social-media-reader",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/CookSleep/chatluna-social-media-reader.git"
    },
    "bugs": {
        "url": "https://github.com/CookSleep/chatluna-social-media-reader/issues"
    },
    "contributors": [
        "CookSleep"
    ],
    "type": "module",
    "main": "lib/index.cjs",
    "module": "lib/index.mjs",
    "typings": "lib/index.d.ts",
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib/index.mjs",
            "require": "./lib/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "lib"
    ],
    "license": "GPL-3.0-only",
    "keywords": [
        "koishi",
        "chatluna",
        "bilibili",
        "xiaohongshu",
        "social-media"
    ],
    "dependencies": {
        "@langchain/core": "^0.3.80",
        "cheerio": "^1.1.2",
        "js-yaml": "^4.1.0",
        "zod": "3.25.76"
    },
    "resolutions": {
        "@langchain/core": "^0.3.80",
        "js-tiktoken": "npm:@dingyi222666/js-tiktoken@^1.0.21"
    },
    "overrides": {
        "@langchain/core": "^0.3.80",
        "js-tiktoken": "npm:@dingyi222666/js-tiktoken@^1.0.21"
    },
    "pnpm": {
        "overrides": {
            "@langchain/core": "^0.3.80",
            "js-tiktoken": "npm:@dingyi222666/js-tiktoken@^1.0.21"
        }
    },
    "devDependencies": {
        "@koishijs/client": "^5.30.11",
        "esbuild": "^0.25.10",
        "koishi": "^4.18.9",
        "koishi-plugin-chatluna": "^1.3.16",
        "koishi-plugin-chatluna-storage-service": "^1.0.1",
        "koishi-plugin-ffmpeg-path": "^2.0.0",
        "typescript": "^5.9.3",
        "yakumo": "^1.0.0",
        "yakumo-esbuild": "^1.0.0",
        "yakumo-tsc": "^1.0.0"
    },
    "peerDependencies": {
        "koishi": "^4.18.9",
        "koishi-plugin-chatluna": "^1.3.0-alpha.49",
        "koishi-plugin-chatluna-storage-service": "^1.0.1",
        "koishi-plugin-ffmpeg-path": "^2.0.0"
    },
    "peerDependenciesMeta": {
        "koishi-plugin-chatluna-storage-service": {
            "optional": true
        }
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "npx yakumo build",
        "fast-build": "npx yakumo build -- --ext=.ts",
        "bump": "npx yakumo version",
        "dep": "npx yakumo upgrade",
        "pub": "npx yakumo publish"
    },
    "koishi": {
        "category": "ai",
        "description": {
            "zh": "为 ChatLuna 提供 B 站与小红书链接读取工具，返回结构化信息与资源链接。"
        },
        "service": {
            "required": [
                "chatluna",
                "ffmpeg",
                "database"
            ]
        }
    }
}
